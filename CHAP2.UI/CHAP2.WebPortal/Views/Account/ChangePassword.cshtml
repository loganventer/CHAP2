@model CHAP2.WebPortal.Models.ChangePasswordViewModel
@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "CHAP2 - Change password";
    ViewData["Subtitle"] = Model.Forced ? "You must set a new password before continuing" : "Change your password";
}

<form method="post" asp-action="ChangePassword" class="login-form" autocomplete="off">
    @Html.AntiForgeryToken()
    <input asp-for="Forced" type="hidden" />
    <input asp-for="CurrentPassword" type="password" placeholder="Current password" autocomplete="current-password" autofocus required />
    <input asp-for="NewPassword" type="password" placeholder="New password" autocomplete="new-password" required />
    <input asp-for="ConfirmNewPassword" type="password" placeholder="Confirm new password" autocomplete="new-password" required />
    <button type="submit"><i class="fas fa-key"></i> Change password</button>
</form>
