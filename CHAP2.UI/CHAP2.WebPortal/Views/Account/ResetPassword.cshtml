@model CHAP2.WebPortal.Models.ResetPasswordViewModel
@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "CHAP2 - Reset password";
    ViewData["Subtitle"] = "Set a new password";
}

<form method="post" asp-action="ResetPassword" class="login-form" autocomplete="off">
    @Html.AntiForgeryToken()
    <input asp-for="ResetToken" type="hidden" />
    <input asp-for="Email" type="email" placeholder="Email" autocomplete="email" required />
    <input asp-for="NewPassword" type="password" placeholder="New password" autocomplete="new-password" autofocus required />
    <input asp-for="ConfirmNewPassword" type="password" placeholder="Confirm new password" autocomplete="new-password" required />
    <button type="submit"><i class="fas fa-key"></i> Reset password</button>
</form>
<div class="login-links">
    <a asp-action="Login">Back to sign in</a>
</div>
