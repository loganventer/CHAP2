@model CHAP2.WebPortal.Models.ForgotPasswordViewModel
@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "CHAP2 - Forgot password";
    ViewData["Subtitle"] = "Get a password reset link by email";
}

<form method="post" asp-action="ForgotPassword" class="login-form" autocomplete="off">
    @Html.AntiForgeryToken()
    <input asp-for="Email" type="email" placeholder="Email" autocomplete="email" autofocus required />
    <button type="submit"><i class="fas fa-paper-plane"></i> Send reset link</button>
</form>
<div class="login-links">
    <a asp-action="Login">Back to sign in</a>
</div>
