@{
    Layout = null;
    var pageTitle = ViewData["Title"] as string ?? "CHAP2";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <link rel="icon" type="image/png" href="~/img/kerk-logo.png" />
    <link rel="apple-touch-icon" href="~/img/kerk-logo.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/buttons.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            margin: 0; min-height: 100vh;
            background: linear-gradient(135deg, #2d2a26 0%, #1f1c18 100%);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            color: #f0ece2; display: flex; align-items: center; justify-content: center; padding: 24px;
        }
        .login-card {
            width: min(420px, 100%); padding: 32px 28px 28px;
            background: rgba(28, 30, 44, 0.6); border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 18px; box-shadow: 0 30px 60px rgba(0, 0, 0, 0.45);
            backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); text-align: center;
        }
        .login-logo {
            width: 5rem; height: 5rem; object-fit: contain; border-radius: 50%;
            filter: brightness(0) invert(1); margin: 0 auto 14px; display: block;
        }
        .login-title { margin: 0 0 4px; font-size: 1.15rem; font-weight: 600; }
        .login-subtitle { margin: 0 0 22px; color: rgba(245, 241, 234, 0.7); font-size: 0.9rem; }
        .login-form { display: flex; flex-direction: column; gap: 12px; text-align: left; }
        .login-form label { font-size: 0.82rem; color: rgba(245, 241, 234, 0.65); margin-bottom: -8px; }
        .login-form input[type="text"], .login-form input[type="password"], .login-form input[type="email"] {
            padding: 12px 14px; background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.12); border-radius: 10px;
            color: #f5f1ea; font-size: 0.95rem; font-family: inherit; outline: none;
            transition: border-color 0.15s ease, background 0.15s ease;
        }
        .login-form input:focus {
            border-color: var(--primary-color, #c9a24a); background: rgba(255, 255, 255, 0.10);
        }
        .login-form button {
            margin-top: 6px; padding: 12px 16px;
            background: linear-gradient(135deg, var(--primary-color, #c9a24a) 0%, var(--primary-dark, #a38336) 100%);
            color: var(--accent-text, #1f1c18); border: none; border-radius: 10px;
            font-size: 0.95rem; font-weight: 600; cursor: pointer;
            transition: filter 0.15s ease, transform 0.1s ease;
        }
        .login-form button:hover { filter: brightness(1.1); }
        .login-form button:active { transform: translateY(1px); }
        .login-error {
            background: rgba(168, 52, 42, 0.18); border: 1px solid rgba(168, 52, 42, 0.45);
            color: #f6c9c5; padding: 10px 12px; border-radius: 8px; font-size: 0.88rem; margin-bottom: 6px;
        }
        .login-info {
            background: rgba(52, 130, 168, 0.18); border: 1px solid rgba(52, 130, 168, 0.45);
            color: #c5e2f6; padding: 10px 12px; border-radius: 8px; font-size: 0.88rem; margin-bottom: 6px;
        }
        .login-links { margin-top: 16px; font-size: 0.85rem; color: rgba(245, 241, 234, 0.65); }
        .login-links a { color: var(--primary-color, #c9a24a); text-decoration: none; }
        .login-links a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <main class="login-card">
        <img src="~/img/kerk-logo.png" alt="" class="login-logo" />
        <h1 class="login-title">Evangelie Kerk van Jesus Christus</h1>
        <p class="login-subtitle">@(ViewData["Subtitle"] ?? "")</p>

        @if (TempData["AccountMessage"] is string msg && !string.IsNullOrWhiteSpace(msg))
        {
            <div class="login-info" role="alert">@msg</div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage))
            {
                if (!string.IsNullOrWhiteSpace(err))
                {
                    <div class="login-error" role="alert">@err</div>
                }
            }
        }

        @RenderBody()
    </main>
</body>
</html>
