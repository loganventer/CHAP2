<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CHAP2 - EKVJC</title>
    <link rel="icon" type="image/png" href="~/img/kerk-logo.png" />
    <link rel="apple-touch-icon" href="~/img/kerk-logo.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/search.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/detail.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/setlist.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/settings.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ai-search.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bible.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/buttons.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="app-container">
        <main id="main-content">
            @RenderBody()
        </main>
    </div>

    <script>
        // Server-rendered identity context: settings.js reads this to decide
        // whether to render admin-only controls (Promote chorus edits to main).
        window.__chap2 = window.__chap2 || {};
        window.__chap2.isAdmin = @Json.Serialize(User?.IsInRole("Admin") ?? false);
        window.__chap2.userName = @Json.Serialize(User?.Identity?.Name ?? "");
    </script>
    <script src="~/js/utils.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/api-status-indicator.js" asp-append-version="true"></script>
    <script src="~/js/search-v2.js" asp-append-version="true"></script>
    <script src="~/js/detail.js" asp-append-version="true"></script>
    <script src="~/js/settings.js" asp-append-version="true"></script>
    <script src="~/js/system-restart.js" asp-append-version="true"></script>
    <script>
        // Populate the mobile sync URL label if present on the page
        (function () {
            var labelEl = document.getElementById('mobileSyncUrl');
            var labelContainer = document.getElementById('mobileSyncLabel');
            if (!labelEl) return;
            fetch('/Home/NetworkInfo')
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.url) {
                        var syncUrl = data.url + '/sync';
                        labelEl.textContent = 'Mobile: ' + syncUrl;
                        if (labelContainer) {
                            labelContainer.style.cursor = 'pointer';
                            labelContainer.title = 'Click to open mobile sync in a new tab';
                            labelContainer.addEventListener('click', function () {
                                window.open('/sync', '_blank');
                            });
                        }
                    } else {
                        labelEl.textContent = 'Network unavailable';
                    }
                })
                .catch(function () { labelEl.textContent = 'Network unavailable'; });
        })();
    </script>
    <environment include="Development">
        <script src="~/js/debug-crud.js" asp-append-version="true"></script>
    </environment>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html> 